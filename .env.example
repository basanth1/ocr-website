# ─── OCR Pipeline Studio — Environment Variables ───────────────────────────
# Copy this file to .env and fill in your values.

# Groq API key (required only for LLM-based section extraction)
GROQ_API_KEY=your_api_key_here

# Flask secret key (change this to a random string in production)
FLASK_SECRET_KEY=change_me_to_a_random_string_in_production

# Upload size limit in MB (default 200)
MAX_UPLOAD_MB=200

# OCR thread count (lower = less RAM usage)
OCR_CPU_THREADS=2
